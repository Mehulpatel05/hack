# OpenAI API Configuration
# Get OpenAI API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Firebase Configuration
# Get Firebase config from: https://console.firebase.google.com
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Server Configuration
PORT=3001
LLM_TIMEOUT_MS=20000
EXTERNAL_TIMEOUT_MS=15000

# SuperBFSI API (Mock for demo - replace with real API)
SUPERBFSI_API_URL=https://api.superbfsi.com
SUPERBFSI_API_KEY=your_api_key_here
