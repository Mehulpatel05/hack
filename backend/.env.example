# LLM API Configuration
# Get Gemini API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OR use Groq (alternative)
# Get Groq API key from: https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here

# Database Configuration
# MongoDB connection string (optional - works without it)
MONGODB_URI=mongodb://localhost:27017/campaignx

# Server Configuration
PORT=3001

# SuperBFSI API (Mock for demo - replace with real API)
SUPERBFSI_API_URL=https://api.superbfsi.com
SUPERBFSI_API_KEY=your_api_key_here
